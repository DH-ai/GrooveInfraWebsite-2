RESEND_API_KEY=re_xxxxxxxxxxxx

# --- Email roles (after grooveinfra.in is verified in Resend) ---
# Public on website — people email you manually (set up forwarding separately)
PUBLIC_CONTACT_EMAIL=contactus@grooveinfra.in

# Your personal inbox — receives "someone submitted the form" alerts
ENQUIRY_INBOX=dhruvastro67@gmail.com

# Form auto-reply to the visitor
NOREPLY_FROM=Groove Infra <noreply@grooveinfra.in>

# Internal enquiry alert sender
ENQUIRY_FROM=Groove Infra Enquiries <enquire@grooveinfra.in>

# Local dev until domain is verified (Resend test sender)
RESEND_USE_TEST_SENDER=true

# Optional: npm run email:test recipient
# TEST_EMAIL_TO=you@gmail.com
